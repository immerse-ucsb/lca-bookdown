  VARIABLE:
  NAMES = bys87a bys87c bys87f bys89a bys89b bys89l bys89r bys89u bys70a bys70b bys70c
       bys70d bytm12b bysex byses2qu bystlang f3bytscwt f3onet2curr stu_id;
